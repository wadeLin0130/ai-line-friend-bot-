# LINE Bot API 設定
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# 主對話模型 (大腦)
MAIN_LLM_API_KEY=your_main_llm_api_key_here
MAIN_LLM_BASE_URL=https://api.openai.com/v1

# 視覺與 Embeddings 向量模型 (支援 OpenAI 或 Gemini 相容模式)
# 【若使用 OpenAI】:
# VISION_API_KEY=你的 OpenAI Key
# VISION_BASE_URL=https://api.openai.com/v1
#
# 【若使用 Gemini (相容模式)】:
# VISION_API_KEY=你的 Gemini API Key (通常以 AIzaSy 開頭)
# VISION_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
VISION_API_KEY=your_vision_api_key_here
VISION_BASE_URL=https://api.openai.com/v1
